# Copie este arquivo para .env.local e preencha com os dados do seu projeto Supabase
# (Project Settings > API no painel do Supabase).

NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-publica

# Usada apenas em scripts server-side confiáveis (nunca exposta ao navegador).
# Necessária para rodar o seed (seção "Seed" do README).
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key
